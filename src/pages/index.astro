---
import BaseLayout from "../layouts/BaseLayout.astro";
import NowBlock from "../components/NowBlock.astro";
import { site } from "../content/site.ts";
---

<BaseLayout>
  <section>
    <div class="eyebrow">{site.name}</div>
    <h1 class="headline">{site.headline}</h1>
    <p class="bio">{site.bio}</p>

    <NowBlock />
  </section>
</BaseLayout>
